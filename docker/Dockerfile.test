FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    curl \
    git \
    tmux \
    gosu \
    ca-certificates \
    gnupg \
    python3 \
    python3-pip \
    jq \
    && rm -rf /var/lib/apt/lists/*

# Install Bun
RUN curl -fsSL https://bun.sh/install | bash && cp /root/.bun/bin/bun /usr/local/bin/bun

# Install Node 20 via nodesource
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install Claude Code globally
RUN npm install -g @anthropic-ai/claude-code

# Install cozempic
RUN pip install cozempic

COPY docker/entrypoint.sh /usr/local/bin/entrypoint.sh
COPY docker/auto_approve.sh /usr/local/bin/auto_approve.sh
RUN chmod +x /usr/local/bin/entrypoint.sh /usr/local/bin/auto_approve.sh

RUN mkdir -p /test-repo
RUN useradd -m -s /bin/bash testuser && chown -R testuser:testuser /test-repo

WORKDIR /test-repo

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
