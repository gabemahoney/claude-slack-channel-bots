{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "declaration": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["bun-types"]
  },
  "include": ["server.ts", "lib.ts", "server.test.ts", "config.ts", "*.test.ts", "tmux.ts", "sessions.ts", "session-manager.ts", "restart.ts"]
}
