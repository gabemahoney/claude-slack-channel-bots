{
  "name": "claude-slack-channel-bots",
  "version": "0.1.0",
  "description": "Multi-session Slack-to-Claude bridge — run multiple Claude Code bots across Slack channels via Socket Mode",
  "type": "module",
  "bin": {
    "claude-slack-channel-bots": "./cli.ts"
  },
  "files": [
    "*.ts",
    "!*.test.ts",
    "hooks/",
    "slack-app-manifest.yml",
    "README.md",
    "skills/"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "start": "bun install --no-summary && bun server.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@slack/socket-mode": "^2.0.0",
    "@slack/web-api": "^7.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.0.0",
    "typescript": "^5.4.0"
  },
  "license": "MIT",
  "author": {
    "name": "Jeremy Longshore",
    "email": "jeremy@intentsolutions.io"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jeremylongshore/claude-code-slack-channel.git"
  }
}
